################################################################################
# SECURITY WARNING
################################################################################
# This is a template file. NEVER commit the actual .env file with real values!
# The .env file should be listed in .gitignore to prevent accidental commits.
#
# NOTE: This project uses GitHub Actions with OIDC for CI/CD.
# No long-lived AWS credentials are needed or stored.
################################################################################

################################################################################
# AWS CONFIGURATION
################################################################################
# AWS Region for infrastructure deployment
AWS_REGION=ca-central-1
AWS_DEFAULT_REGION=ca-central-1

################################################################################
# OPENTOFU BACKEND CONFIGURATION (Remote State)
################################################################################
# S3 Backend Configuration for storing OpenTofu state files remotely

# S3 bucket name for storing state files
TF_BACKEND_BUCKET=chew-site-tfstate

# S3 key prefix for state files (environment-specific)
TF_BACKEND_KEY=dev/terraform.tfstate

# AWS region where the state bucket is located
TF_BACKEND_REGION=ca-central-1

# DynamoDB table name for state locking
TF_BACKEND_DYNAMODB_TABLE=chew-site-tfstate-lock

# Enable encryption for state files
TF_BACKEND_ENCRYPT=true

################################################################################
# PROJECT VARIABLES
################################################################################
# These variables are passed to OpenTofu as TF_VAR_* environment variables

# Environment name (dev, prod)
TF_VAR_environment=dev

# Project name (used for resource naming and tagging)
TF_VAR_project_name=chew-site

# Domain name for the website
TF_VAR_domain_name=example.com

################################################################################
# NETWORKING CONFIGURATION
################################################################################
# VPC CIDR block
TF_VAR_vpc_cidr=10.0.0.0/16

# Availability Zones (comma-separated)
TF_VAR_availability_zones=ca-central-1a,ca-central-1b

################################################################################
# STORAGE CONFIGURATION
################################################################################
# S3 bucket name for website content
TF_VAR_website_bucket_name=chew-site-content

# Enable S3 bucket versioning
TF_VAR_enable_s3_versioning=true

################################################################################
# CDN / CLOUDFRONT CONFIGURATION
################################################################################
# Enable CloudFront CDN
TF_VAR_enable_cloudfront=true

# CloudFront price class
# PriceClass_100: US, Canada, Europe
# PriceClass_200: US, Canada, Europe, Asia, Middle East, Africa
# PriceClass_All: All edge locations worldwide
TF_VAR_cloudfront_price_class=PriceClass_100

################################################################################
# MONITORING & LOGGING
################################################################################
# Enable CloudWatch logging
TF_VAR_enable_cloudwatch=true

# CloudWatch log retention (in days)
TF_VAR_log_retention_days=7

################################################################################
# SECURITY & COMPLIANCE
################################################################################
# Enable S3 bucket encryption
TF_VAR_enable_s3_encryption=true

################################################################################
# RESOURCE TAGGING
################################################################################
# Standard tags applied to all resources
TF_VAR_managed_by=opentofu
TF_VAR_owner=infrastructure-team
TF_VAR_cost_center=engineering

################################################################################
# DEVELOPMENT & DEBUGGING
################################################################################
# Enable OpenTofu debug logging (trace, debug, info, warn, error)
# TF_LOG=info

# OpenTofu log file path
# TF_LOG_PATH=./tofu-debug.log

################################################################################
# USAGE NOTES
################################################################################
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in actual values in .env
# 3. Never commit .env to version control
# 4. CI/CD uses GitHub Actions OIDC (no AWS keys needed in GitHub Secrets)
# 5. Variables prefixed with TF_VAR_ are automatically passed to OpenTofu
################################################################################
