# OpenTofu/Terraform state files
# These contain sensitive data about your infrastructure
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfstate.*.backup
terraform.tfstate
terraform.tfstate.backup
terraform.tfstate.*.backup

# OpenTofu/Terraform variable files with secrets
# Never commit files containing credentials or sensitive values
*.tfvars
*.tfvars.json
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
# Exception: you may commit example/template files
!*.tfvars.example
!*.tfvars.template

# OpenTofu/Terraform directories
.terraform/
.terraform.lock.hcl
*.tfplan
*.tfplan.*

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# AWS Credentials and Secrets
# NEVER commit any credential files
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.der
credentials
credentials.csv
credentials.json
aws-credentials
aws-credentials.*
accessKeys.csv

# Environment files with secrets
.env
.env.*
.envrc
!.env.example
!.env.template
!.env.sample

# Password and secrets files
secrets.*
secret.*
*.secret
*.secrets
*secret*.yaml
*secret*.yml
*secret*.json

# IDE and Editor files
# VS Code
.vscode/
.code-workspace
*.code-workspace

# JetBrains IDEs (IntelliJ, PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.*.sw?
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.\#*
.dir-locals.el

# TextMate
*.tmproj
*.tmproject
tmtags

# macOS files
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux files
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# Windows files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Backup files
*.bak
*.backup
*.bkp
*.orig
*.tmp
*.temp
*~

# Log files
*.log
logs/
*.log.*

# Archive files (often used for backups)
*.tar
*.tar.gz
*.tgz
*.zip
*.rar
*.7z

# Local development and testing
.local/
local/
tmp/
temp/
test-results/
.cache/

# Package manager directories
node_modules/
vendor/

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/
ENV/

# Go
go.sum

# Ignore all dotfiles except specific ones
.*
!.gitignore
!.gitattributes
!.editorconfig
!.env.example
!.env.template
!.env.sample
!.terraform-version
!.tool-versions
!.pre-commit-config.yaml
